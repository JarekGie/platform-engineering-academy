# EditorConfig — spójny styl plików w repo. https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown: dwie spacje na końcu linii bywają celowe (twarde łamanie), nie przycinaj.
[*.md]
trim_trailing_whitespace = false

# Makefile WYMAGA tabulatorów w regułach — nie zamieniaj na spacje.
[Makefile]
indent_style = tab

[{*.tf,*.hcl}]
indent_size = 2

[*.{py,go}]
indent_size = 4

[*.go]
indent_style = tab
